#!/usr/bin/env bash
# Commit-msg hook to enforce explicit attribution approval for co-author trailers.

set -euo pipefail

if [[ "$#" -ne 1 ]]; then
  echo "Usage: commit-msg <commit-message-file>" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

"$SCRIPT_DIR/check_commit_attribution.sh" --message-file "$1"
